# Arena server config — env only, no config files. The hub pattern keeps real
# values in a SOPS-encrypted file and decrypts at deploy time:
#   sops -d secrets.enc.yaml > .env
# (No secrets.enc.yaml in this repo yet — create it on the deploy host.)

# void-mail delivery (required unless MOCK_MODE=1)
MAIL_BASE_URL=https://mail.example.com
MAIL_TOKEN=replace-me

# Optional — defaults shown; the image already sets DB_PATH and STATIC_DIR.
#PORT=8787
#DB_PATH=/data/arena.db
#STATIC_DIR=/app/public

# e2e/dev ONLY — mocks the mailer and mounts an OTP-code oracle
# (/_mock/last-code). Never set in production.
#MOCK_MODE=1
