node_modules/
dist/

# Creation-worker output — a worker emits its candidate here per task; the
# committed golden inputs live in tasks/*/fixtures/, never clobbered.
tasks/*/out/

# Screenshot-walk output — human-inspection PNGs, never committed.
e2e/.shots/

# Warm-stack pidfile written by `npm run e2e:serve`, read by `npm run e2e:stop`.
.e2e-serve.json
